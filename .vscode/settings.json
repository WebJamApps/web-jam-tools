{
  // Deno config for the task-queue tool. SCOPED via deno.enablePaths so the
  // Deno language server only governs Deno code — src/, test/, and the Deno
  // audit helper scripts/audit/ (gen-npm-manifest.ts uses `Deno.*`). The rest of
  // scripts/ (Node TS via tsx) and gig-scraper (Node/JS) keep their normal
  // language servers. Without this, the built-in TS server would flag `Deno.*`
  // globals and `jsr:`/`@std/` imports as errors.
  "deno.enablePaths": ["src", "test", "scripts/audit"],
  "deno.lint": true,
  "deno.unstable": false,
  // Format-on-save via `deno fmt`. The Deno formatter only operates on files
  // inside enablePaths; TS files elsewhere (scripts/*.ts) just won't be
  // auto-formatted by it, so nothing Node-side is reformatted unexpectedly.
  "[typescript]": {
    "editor.defaultFormatter": "denoland.vscode-deno"
  }
}
