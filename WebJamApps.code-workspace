{
  "folders": [
    { "name": "JaMmusic", "path": "JaMmusic" },
    { "name": "CollegeLutheran", "path": "CollegeLutheran" },
    { "name": "AppersonAuto", "path": "AppersonAuto" },
    { "name": "web-jam-back", "path": "web-jam-back" },
    { "name": "WebJamSocketCluster", "path": "WebJamSocketCluster" },
    { "name": "WebJamPg", "path": "WebJamPg" },
    { "name": "web-jam-tools", "path": "web-jam-tools" },
    { "name": "web-jam-llms", "path": "web-jam-llms" }
  ],
  "settings": {
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.fixAll.eslint": "explicit",
      "source.fixAll.stylelint": "explicit"
    },
    "eslint.workingDirectories": [
      { "pattern": "./*" }
    ],
    "vitest.disableWorkspaceWarning": true,
    "files.exclude": {
      "**/node_modules": true,
      "**/.git": true,
      "**/coverage": true,
      "**/dist": true
    },
    "search.exclude": {
      "**/node_modules": true,
      "**/coverage": true,
      "**/dist": true,
      "**/package-lock.json": true
    },
    "typescript.tsdk": "JaMmusic/node_modules/typescript/lib",
    "typescript.enablePromptUseWorkspaceTsdk": true,
    "git.ignoredRepositories": [
      "/home/joshua/WebJamApps/web-jam-back/JaMmusic",
      "/home/joshua/WebJamApps/WebJamSocketCluster/JaMmusic"
    ],
    "python.terminal.activateEnvironment": false
  },
  "extensions": {
    "recommendations": [
      "vitest.explorer",
      "dbaeumer.vscode-eslint",
      "esbenp.prettier-vscode",
      "stylelint.vscode-stylelint",
      "eamodio.gitlens",
      "google.gemini-cli-vscode-ide-companion",
      "google.geminicodeassist"
    ],
    "unwantedRecommendations": [
      "orta.vscode-jest",
      "hbenl.vscode-test-explorer",
      "ms-vscode.test-adapter-converter"
    ]
  },
  "tasks": {
    "version": "2.0.0",
    "tasks": [
      {
        "label": "web-jam-back: dev (install + run)",
        "type": "shell",
        "command": "npm install --ignore-scripts && (fuser -k 7000/tcp 2>/dev/null || true) && PORT=7000 npm run dev",
        "options": {
          "cwd": "${workspaceFolder:web-jam-back}",
          "shell": { "executable": "/bin/bash", "args": ["-l", "-c"] }
        },
        "presentation": {
          "panel": "new",
          "reveal": "always",
          "focus": false,
          "showReuseMessage": false,
          "clear": true
        },
        "isBackground": true,
        "problemMatcher": []
      },
      {
        "label": "WebJamSocketCluster: dev (install + run)",
        "type": "shell",
        "command": "npm install --ignore-scripts && (fuser -k 8000/tcp 2>/dev/null || true) && PORT=8000 npm run dev",
        "options": {
          "cwd": "${workspaceFolder:WebJamSocketCluster}",
          "shell": { "executable": "/bin/bash", "args": ["-l", "-c"] }
        },
        "presentation": {
          "panel": "new",
          "reveal": "always",
          "focus": false,
          "showReuseMessage": false,
          "clear": true
        },
        "isBackground": true,
        "problemMatcher": []
      },
      {
        "label": "JaMmusic: dev (install + run)",
        "type": "shell",
        "command": "npm install && (fuser -k 7878/tcp 2>/dev/null || true) && npm run dev",
        "options": {
          "cwd": "${workspaceFolder:JaMmusic}",
          "shell": { "executable": "/bin/bash", "args": ["-l", "-c"] }
        },
        "presentation": {
          "panel": "new",
          "reveal": "always",
          "focus": false,
          "showReuseMessage": false,
          "clear": true
        },
        "isBackground": true,
        "problemMatcher": []
      },
      {
        "label": "CollegeLutheran: dev (install + run)",
        "type": "shell",
        "command": "npm install && (fuser -k 7777/tcp 2>/dev/null || true) && npm run dev",
        "options": {
          "cwd": "${workspaceFolder:CollegeLutheran}",
          "shell": { "executable": "/bin/bash", "args": ["-l", "-c"] }
        },
        "presentation": {
          "panel": "new",
          "reveal": "always",
          "focus": false,
          "showReuseMessage": false,
          "clear": true
        },
        "isBackground": true,
        "problemMatcher": []
      },
      {
        "label": "AppersonAuto: dev (install + run)",
        "type": "shell",
        "command": "npm install && (fuser -k 7779/tcp 2>/dev/null || true) && npm run dev",
        "options": {
          "cwd": "${workspaceFolder:AppersonAuto}",
          "shell": { "executable": "/bin/bash", "args": ["-l", "-c"] }
        },
        "presentation": {
          "panel": "new",
          "reveal": "always",
          "focus": false,
          "showReuseMessage": false,
          "clear": true
        },
        "isBackground": true,
        "problemMatcher": []
      },
      {
        "label": "Start All Apps (dev)",
        "dependsOn": [
          "web-jam-back: dev (install + run)",
          "WebJamSocketCluster: dev (install + run)",
          "JaMmusic: dev (install + run)",
          "CollegeLutheran: dev (install + run)",
          "AppersonAuto: dev (install + run)"
        ],
        "dependsOrder": "parallel",
        "problemMatcher": []
      },
      {
        "label": "Start backend + socket cluster (dev)",
        "dependsOn": [
          "web-jam-back: dev (install + run)",
          "WebJamSocketCluster: dev (install + run)"
        ],
        "dependsOrder": "parallel",
        "problemMatcher": []
      },
      {
        "label": "Gemma: Coordinator REPL (gemma)",
        "type": "shell",
        "command": "gemma",
        "presentation": {
          "panel": "dedicated",
          "reveal": "always",
          "focus": true,
          "showReuseMessage": false,
          "clear": false
        },
        "problemMatcher": []
      }
    ]
  }
}
